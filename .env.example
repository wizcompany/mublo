###########################################################
# 🚀 Application Environment
# - 개발 환경 설정 (config 파일과 별개로 환경별 설정)
# - 이 파일을 복사하여 .env 파일 생성 후 사용
#
# 참고: DB, 암호화 키 등 민감 정보는 설치 시
#      config/ 디렉토리에 자동 생성됩니다.
###########################################################
APP_DEBUG=false
APP_ENV=production

###########################################################
# ⚙️ Cache & Session Driver
# - 기본은 파일 기반, 필요 시 redis 확장
# - file | redis
###########################################################
CACHE_DRIVER=file
SESSION_DRIVER=file

###########################################################
# 🔴 Redis Configuration
# - CACHE_DRIVER 또는 SESSION_DRIVER가 redis일 때만 사용
###########################################################
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

###########################################################
# 📧 Mail Configuration
# - driver: mail (PHP mail 함수) | smtp (SMTP 서버)
# - SMTP 설정은 driver가 smtp일 때만 사용
###########################################################
MAIL_DRIVER=mail
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Mublo
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
