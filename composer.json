{
    "name": "mublo/framework",
    "description": "Mublo Framework - Multi-domain CMS platform",
    "license": "MIT",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Mublo\\": "src/",
            "Mublo\\Plugin\\": "plugins/",
            "Mublo\\Packages\\": "packages/",
            "Tests\\": "tests/",
            "Tests\\Shop\\": "packages/Shop/tests/"
        },
        "files": [
            "src/Helper/EnvHelpers.php"
        ]
    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "nikic/fast-route": "^1.3",
        "ramsey/uuid": "^4.7",
        "guzzlehttp/guzzle": "^7.9",
        "monolog/monolog": "^3.7",
        "symfony/cache": "^7.1",
        "ezyang/htmlpurifier": "^4.18",
        "psr/container": "^2.0",
        "intervention/image": "^3.8",
        "phpoffice/phpspreadsheet": "^5.4",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "dompdf/dompdf": "^3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.50"
    },
    "scripts": {
        "check-di": "php tools/check-di-violations.php",
        "test": "phpunit",
        "check": [
            "@check-di",
            "@test"
        ]
    }
}
